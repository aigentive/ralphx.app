# Logs (keep activity.md and code-quality files)
logs/*
!logs/activity.md
!logs/code-quality.md
!logs/code-quality-archive.md
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Cache
.cache/
node_modules
node_modules/

# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*.local

# Build outputs
dist/
dist-ssr/
build/
out/

# Rust/Tauri
src-tauri/target/
src-tauri/gen/schemas

# Playwright
playwright-report/
test-results/

# Screenshots (track mock-check.md evidence, ignore PNGs)
screenshots/**/*.png
!screenshots/**/*_mock-check.md
!screenshots/.gitkeep
*.db
.ralph-stop
.commit-lock
.stream-*-lock
.stream-*-mtimes
streams/hygiene/trigger
