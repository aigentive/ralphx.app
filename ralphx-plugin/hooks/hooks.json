{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/rule-manager/scripts/rule-audit.sh --brief"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-rule-manager.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/commit-memory-files.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enforce-knowledge-capture.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Verify task completion: check acceptance criteria, ensure tests pass, and update task status in the activity log. If there is no task context (general session without defined tasks), respond {\"ok\": true}. Context: $ARGUMENTS"
          }
        ]
      }
    ]
  }
}
