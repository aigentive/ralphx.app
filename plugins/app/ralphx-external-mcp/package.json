{
  "name": "ralphx-external-mcp",
  "version": "1.0.0",
  "description": "External MCP server for RalphX — enables external agents to orchestrate RalphX via MCP over HTTP+SSE",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "ralphx",
    "model-context-protocol",
    "external-api"
  ],
  "author": "RalphX",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
