#!/usr/bin/env bash
# RalphX pre-commit hook
#
# Three guards:
#   1. Reject node_modules paths (worktree agents create symlinks that must
#      never be committed).
#   2. Tauri version alignment (frontend/package.json, src-tauri/Cargo.toml
#      and their lockfiles must stay in sync).
#   3. Design-token guards + typecheck + lint on staged frontend changes.
#
# Install: `npm --prefix frontend run hooks:install` (sets core.hooksPath)
# Bypass with `git commit --no-verify` only when absolutely necessary.

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ----------------------------------------------------------------------------
# Guard 1 — node_modules in staged paths
# ----------------------------------------------------------------------------
staged=$(git diff --cached --name-only --diff-filter=ACMR)
bad=$(echo "$staged" | grep -E '(^|/)node_modules(/|$)' || true)
if [ -n "$bad" ]; then
  echo "ERROR: Refusing to commit node_modules paths:"
  echo "$bad" | sed 's/^/  /'
  echo ""
  echo "These are likely worktree symlinks. Remove them from staging:"
  echo "  git reset HEAD <path>"
  exit 1
fi

# ----------------------------------------------------------------------------
# Guard 2 — Tauri version alignment
# ----------------------------------------------------------------------------
tauri_version_files=$(echo "$staged" | grep -E '^(frontend/package\.json|frontend/package-lock\.json|src-tauri/Cargo\.toml|src-tauri/Cargo\.lock)$' || true)

if [ -n "$tauri_version_files" ]; then
    if ! mismatch_report="$(node "$HOOK_DIR/../scripts/check-tauri-package-alignment.mjs" "$REPO_ROOT")"; then
        echo "ERROR: Refusing to commit Tauri version drift:"
        echo "$mismatch_report" | sed 's/^/  /'
        echo ""
        echo "Align the staged Tauri manifest and lockfile updates before committing."
        exit 1
    fi
fi

# ----------------------------------------------------------------------------
# Guard 3 — frontend design-system + typecheck + lint
# Only runs when frontend files are staged (keeps backend/docs commits fast).
# ----------------------------------------------------------------------------
staged_frontend=$(echo "$staged" | grep -E '^frontend/(src|scripts|tests)/' || true)
if [ -z "$staged_frontend" ]; then
  exit 0
fi

cd frontend

printf '\033[1m[pre-commit]\033[0m design-token guards…\n'
./scripts/check-design-tokens.sh

printf '\n\033[1m[pre-commit]\033[0m typecheck…\n'
npm run -s typecheck

printf '\n\033[1m[pre-commit]\033[0m lint (staged .ts/.tsx only)…\n'
staged_src=$(echo "$staged_frontend" | sed -n 's|^frontend/||p' | grep -E '^src/.*\.tsx?$' || true)
if [ -n "$staged_src" ]; then
  # shellcheck disable=SC2086
  npx eslint --max-warnings=0 $staged_src
else
  printf '(no staged .ts/.tsx files in src/)\n'
fi

printf '\n\033[32m[pre-commit] all checks passed\033[0m\n'
