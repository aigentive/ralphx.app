#!/usr/bin/env bash
# RalphX pre-commit hook
#
# Three guards:
#   1. Reject node_modules paths (worktree agents create symlinks that must
#      never be committed).
#   2. Tauri version alignment (frontend/package.json, src-tauri/Cargo.toml
#      and their lockfiles must stay in sync).
#   3. Design-token guards + typecheck + lint on staged frontend changes.
#      Worktree commits reuse primary checkout dependencies unless staged
#      dependency manifests require a worktree-local install.
#
# Install: `npm --prefix frontend run hooks:install` (sets core.hooksPath)
# Bypass with `git commit --no-verify` only when absolutely necessary.

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ----------------------------------------------------------------------------
# Guard 1 — node_modules in staged paths
# ----------------------------------------------------------------------------
staged=$(git diff --cached --name-only --diff-filter=ACMR)
bad=$(echo "$staged" | grep -E '(^|/)node_modules(/|$)' || true)
if [ -n "$bad" ]; then
  echo "ERROR: Refusing to commit node_modules paths:"
  echo "$bad" | sed 's/^/  /'
  echo ""
  echo "These are likely worktree symlinks. Remove them from staging:"
  echo "  git reset HEAD <path>"
  exit 1
fi

# ----------------------------------------------------------------------------
# Guard 2 — Tauri version alignment
# ----------------------------------------------------------------------------
tauri_version_files=$(echo "$staged" | grep -E '^(frontend/package\.json|frontend/package-lock\.json|src-tauri/Cargo\.toml|src-tauri/Cargo\.lock)$' || true)

if [ -n "$tauri_version_files" ]; then
    if ! mismatch_report="$(node "$HOOK_DIR/../scripts/check-tauri-package-alignment.mjs" "$REPO_ROOT")"; then
        echo "ERROR: Refusing to commit Tauri version drift:"
        echo "$mismatch_report" | sed 's/^/  /'
        echo ""
        echo "Align the staged Tauri manifest and lockfile updates before committing."
        exit 1
    fi
fi

# ----------------------------------------------------------------------------
# Guard 3 — frontend design-system + typecheck + lint
# Only runs when frontend files are staged (keeps backend/docs commits fast).
# ----------------------------------------------------------------------------
staged_frontend=$(echo "$staged" | grep -E '^frontend/(src|scripts|tests)/' || true)
if [ -z "$staged_frontend" ]; then
  exit 0
fi

resolve_primary_root() {
  local common_git_dir

  if ! common_git_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"; then
    common_git_dir="$(git rev-parse --git-common-dir)"
    case "$common_git_dir" in
      /*) ;;
      *) common_git_dir="$REPO_ROOT/$common_git_dir" ;;
    esac
  fi

  cd "$common_git_dir/.." && pwd
}

ensure_frontend_dependencies() {
  local dependency_manifest_changes primary_root primary_node_modules

  dependency_manifest_changes=$(echo "$staged" | grep -E '^frontend/(package\.json|package-lock\.json)$' || true)

  if [ -n "$dependency_manifest_changes" ]; then
    if [ -L node_modules ]; then
      rm -f node_modules
    fi

    printf '\033[1m[pre-commit]\033[0m dependency manifests changed; installing worktree frontend deps…\n'
    if [ -f package-lock.json ]; then
      npm ci --prefer-offline --no-audit --no-fund
    else
      npm install --prefer-offline --no-audit --no-fund
    fi
    return
  fi

  if [ -d node_modules ]; then
    return
  fi

  if [ -L node_modules ]; then
    rm -f node_modules
  elif [ -e node_modules ]; then
    echo "ERROR: frontend/node_modules exists but is not a directory or symlink."
    echo "Remove it and retry the commit."
    exit 1
  fi

  primary_root="$(resolve_primary_root)"
  primary_node_modules="$primary_root/frontend/node_modules"

  if [ "$primary_root" != "$REPO_ROOT" ] && [ -d "$primary_node_modules" ]; then
    printf '\033[1m[pre-commit]\033[0m linking frontend/node_modules from primary checkout…\n'
    ln -s "$primary_node_modules" node_modules
    return
  fi

  echo "ERROR: frontend/node_modules is missing in this worktree and no primary checkout dependency install is available."
  echo ""
  echo "Install frontend dependencies in the primary checkout, then retry:"
  echo "  npm --prefix \"$primary_root/frontend\" install"
  echo ""
  echo "If this commit changes frontend dependencies, stage the updated lockfile so the hook can run npm ci in this worktree."
  exit 1
}

cd frontend
ensure_frontend_dependencies

printf '\033[1m[pre-commit]\033[0m design-token guards…\n'
./scripts/check-design-tokens.sh

printf '\n\033[1m[pre-commit]\033[0m typecheck…\n'
npm run -s typecheck

printf '\n\033[1m[pre-commit]\033[0m lint (staged .ts/.tsx only)…\n'
staged_src=$(echo "$staged_frontend" | sed -n 's|^frontend/||p' | grep -E '^src/.*\.tsx?$' || true)
if [ -n "$staged_src" ]; then
  # shellcheck disable=SC2086
  npx eslint --max-warnings=0 $staged_src
else
  printf '(no staged .ts/.tsx files in src/)\n'
fi

printf '\n\033[32m[pre-commit] all checks passed\033[0m\n'
